---
import CaseCard from './CaseCard.astro';

interface Project { title: string; href: string; year: number; }
interface Props {
  label: string;
  title: string;
  projects: Project[];
}
const { label, title, projects } = Astro.props;
---

<section id="side-projects" class="side-projects">
  <div class="side-projects__container">

    <div class="side-projects__header" data-animate-sp>
      <p class="side-projects__label">{label}</p>
      <h2 class="side-projects__title">{title}</h2>
    </div>

    <ul class="side-projects__list">
      {projects.map((p, i) => (
        <div data-animate-sp style={`transition-delay: ${i * 0.15}s`}>
          <CaseCard
            index={i + 1}
            title={p.title}
            href={p.href}
            year={p.year}
            variant="secondary"
          />
        </div>
      ))}
    </ul>

  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.side-projects [data-animate-sp]').forEach(el => observer.observe(el));
</script>

<style>
  .side-projects {
    padding: var(--section-spacing) var(--spacing-container);
    background: var(--color-bg);
  }

  .side-projects__container {
    margin: 0 auto;
  }

  [data-animate-sp] {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  [data-animate-sp].visible {
    opacity: 1;
    transform: none;
  }

  .side-projects__header {
    margin-bottom: 4rem;
    padding-bottom: 2rem;
    position: relative;
  }

  .side-projects__header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-text-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .side-projects__header.visible::after {
    transform: scaleX(1);
  }

  .side-projects__label {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 11px;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 1.5rem;
  }

  .side-projects__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.2;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 400;
  }

  .side-projects__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
