---
interface Props {
  number: string;
  title: string;
  description: string;
  count: number;
  [key: string]: unknown;
}

const { number, title, description, count, ...rest } = Astro.props;
---

<div class="service-card" {...rest}>
  <div class="service-card__top">
    <span class="service-card__number">{number}</span>
    <div class="service-card__line"></div>
    <div class="service-card__badge">
      <span class="service-card__badge-text">{count} PROJETS</span>
    </div>
  </div>
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__description">{description}</p>
</div>

<style>
  .service-card {
    border: var(--card-border);
    border-radius: var(--card-radius);
    background: var(--color-surface);
    padding: var(--spacing-block);
    height: 220px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 18px;
    cursor: help;
    transition: border-color 0.25s ease;
  }

  .service-card:hover {
    border-color: var(--color-text-primary);
  }

  /* --- Top row --- */
  .service-card__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .service-card__number {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .service-card__line {
    height: 1px;
    flex: 1;
    background: var(--color-border);
  }

  .service-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-border);
    border-radius: 2px;
    padding: 2px 4px;
    transition: background-color 0.25s ease;
  }

  .service-card:hover .service-card__badge {
    background-color: var(--color-text-primary);
  }

  .service-card__badge-text {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.16px;
    color: var(--color-text-muted);
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .service-card:hover .service-card__badge-text {
    color: var(--color-surface);
  }

  .service-card__title {
    font-size: 26px;
    line-height: 1.3;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .service-card__description {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-weight: 300;
  }
</style>
