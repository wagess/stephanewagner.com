---
interface Props {
  number: string;
  title: string;
  description: string;
  count: number;
  href?: string;
  [key: string]: unknown;
}

const { number, title, description, count, href, ...rest } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="service-card" href={href || undefined} {...rest}>
  <div class="service-card__top">
    <span class="service-card__number">{number}</span>
    <div class="service-card__line"></div>
    <div class="service-card__badge">
      <span class="service-card__badge-text">{count} PROJETS</span>
    </div>
  </div>
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__description">{description}</p>
</Tag>

<style>
  .service-card {
    border: var(--card-border);
    border-radius: var(--card-radius);
    background: var(--color-surface);
    padding: var(--spacing-block);
    height: 100%;
    min-height: 24s0px;
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    cursor: pointer;
    text-decoration: none;
    transform: translateZ(0);
    will-change: border-color;
    transition: border-color var(--transition-base);

    &:hover {
      border-color: var(--color-text-primary);

      & .service-card__badge {
        background-color: var(--color-text-primary);
      }

      & .service-card__badge-text {
        color: var(--color-surface);
        transition: color var(--transition-base);
      }
    }
  }

  /* --- Top row --- */
  .service-card__top {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
  }

  .service-card__number {
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-mono);
    color: var(--color-text-muted);
  }

  .service-card__line {
    height: 1px;
    flex: 1;
    background: var(--color-border);
  }

  .service-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2px 4px;
    will-change: background-color;
    transition: background-color var(--transition-base);
  }

  .service-card__badge-text {
    font-family: var(--font-mono);
    font-size: 9px;
    line-height: 1.2;
    letter-spacing: 0.16px;
    color: var(--color-text-muted);
    white-space: nowrap;
    transition: color var(--transition-base);
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-card-title);
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
  }

  .service-card__description {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }
</style>
