<style>
  .footer {
    width: 100%;
    border-top: 1px solid var(--color-border);
    padding: var(--gap-block) var(--spacing-container);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__left {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--gap-sm);
    }

    .footer__left {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer__label {
      display: none;
    }
  }

  .footer__label {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .footer__logos {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text-primary);
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }

  .footer__logo:hover {
    opacity: 1;
  }

  .footer__logo--brain {
    cursor: default;
  }

  .footer__logo svg {
    flex-shrink: 0;
  }

  .footer__right {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-shrink: 0;
  }

  .footer__brand-logo {
    height: 20px;
    width: auto;
    max-width: 80px;
    opacity: 0.5;
  }

  .footer__links {
    display: flex;
    gap: 1.25rem;
  }

  .footer__link {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-primary);
    opacity: 0.4;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }

  .footer__link:hover {
    opacity: 1;
  }

  .footer__link--dev {
    color: #8619e0;
  }
</style>
