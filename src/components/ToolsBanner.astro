---

<div class="banner-wrap">
  <div class="banner">
    <div class="track">
      {[...tools, ...tools, ...tools].map(tool => (
        <span class="tool">
          <span class="tool__icon" set:html={tool.svg} />
          <span class="tool__name">{tool.name}</span>
        </span>
      ))}
    </div>
  </div>
</div>

<div class="clients-wrap">
  <div class="clients-banner">
    <div class="clients-track">
      {[0, 1, 2].map(i => (
        <>
          <span class="client client--logo">
            <span class="client__logo" set:html={fakeLogo} />
          </span>
          {clients.map(client => (
            <span class="client">{client}</span>
          ))}
        </>
      ))}
    </div>
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .banner-wrap {
      display: none;
    }
  }

  .banner-wrap {
    overflow: hidden;
    transform: rotate(-1deg);
    margin: -0.5rem 0;
    position: relative;
    top: -100px;
    position: relative;
    z-index: 10;
  }

  .banner {
    background: var(--color-accent);
    padding: 0.875rem 0;
    width: 110%;
    margin-left: -5%;
    overflow: hidden;
  }

  .track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: scroll 35s linear infinite;
  }

  .track:hover {
    animation-play-state: paused;
  }

  .tool {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    white-space: nowrap;
    padding: 0 2rem;
    border-right: 1px solid rgba(255,255,255,0.2);
  }

  .tool__icon {
    display: flex;
    align-items: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .tool__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-100% / 3)); }
  }

  /* Clients banner */
  .clients-wrap {
    overflow: hidden;
    transform: rotate(-1deg);
    margin: -0.5rem 0;
    position: relative;
    top: -96px;
    z-index: 9;
  }

  .clients-banner {
    background: var(--color-border);
    padding: 2rem 0;
    width: 110%;
    margin-left: -5%;
    overflow: hidden;
  }

  .clients-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: scroll-reverse 110s linear infinite;
  }

  .clients-track:hover {
    animation-play-state: paused;
  }

  .client {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
    white-space: nowrap;
    padding: 0 2.5rem;
    border-right: 1px solid rgba(0, 0, 0, 0.1);
  }

  .client--logo {
    padding: 0 2rem;
  }

  .client__logo {
    display: flex;
    align-items: center;
    color: var(--color-surface);
    height: 20px;
  }

  .client__logo :global(svg) {
    height: 100%;
    width: auto;
  }

  @keyframes scroll-reverse {
    from { transform: translateX(calc(-100% / 3)); }
    to   { transform: translateX(0); }
  }
</style>
