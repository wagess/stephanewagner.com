---
import adobeCloudLogo from '../assets/logos/AdobeCloud.svg?raw';
import adobeLrLogo from '../assets/logos/AdobeLr.svg?raw';
import adobePsLogo from '../assets/logos/AdobePs.svg?raw';
import claudeLogo from '../assets/logos/Claude.svg?raw';
import figmaLogo from '../assets/logos/Figma.svg?raw';
import githubLogo from '../assets/logos/Github.svg?raw';
import gitlabLogo from '../assets/logos/Gitlab.svg?raw';
import googleDocLogo from '../assets/logos/Google doc.svg?raw';
import googleFormLogo from '../assets/logos/Google form.svg?raw';
import googleSheetLogo from '../assets/logos/Google sheet.svg?raw';
import googleLogo from '../assets/logos/Google.svg?raw';
import googleChatLogo from '../assets/logos/GoogleChat.svg?raw';
import microsoftLogo from '../assets/logos/Microsoft.svg?raw';
import miroLogo from '../assets/logos/Miro.svg?raw';
import onedriveLogo from '../assets/logos/Onedrive.svg?raw';
import openaiLogo from '../assets/logos/OpenAI.svg?raw';
import playStoreLogo from '../assets/logos/Play Store.svg?raw';
import mailchimpLogo from '../assets/logos/mailchimp.svg?raw';

interface Props {
  tools: string[];
  clients: string[];
}
const { tools: toolNames, clients } = Astro.props;

const allTools = [
  { name: 'Figma',        svg: figmaLogo },
  { name: 'GitHub',       svg: githubLogo },
  { name: 'GitLab',       svg: gitlabLogo },
  { name: 'Claude',       svg: claudeLogo },
  { name: 'OpenAI',       svg: openaiLogo },
  { name: 'Miro',         svg: miroLogo },
  { name: 'Microsoft',    svg: microsoftLogo },
  { name: 'OneDrive',     svg: onedriveLogo },
  { name: 'Adobe Cloud',  svg: adobeCloudLogo },
  { name: 'Photoshop',    svg: adobePsLogo },
  { name: 'Lightroom',    svg: adobeLrLogo },
  { name: 'Google',       svg: googleLogo },
  { name: 'Google Docs',  svg: googleDocLogo },
  { name: 'Google Sheets',svg: googleSheetLogo },
  { name: 'Google Forms', svg: googleFormLogo },
  { name: 'Google Chat',  svg: googleChatLogo },
  { name: 'Play Store',   svg: playStoreLogo },
  { name: 'Mailchimp',    svg: mailchimpLogo },
];

const svgMap = Object.fromEntries(allTools.map(t => [t.name, t.svg]));
const tools = toolNames.map(name => ({ name, svg: svgMap[name] ?? '' }));
---

<div class="banner-wrap hide-mobile">
  <div class="banner">
    <div class="track">
      {[...tools, ...tools, ...tools].map(tool => (
        <span class="tool">
          <span class="tool__icon" set:html={tool.svg} />
          <span class="tool__name">{tool.name}</span>
        </span>
      ))}
    </div>
  </div>
</div>

<div class="clients-wrap hide-mobile">
  <div class="clients-banner">
    <div class="clients-track">
      {[...clients, ...clients, ...clients].map(client => (
        <span class="client">{client}</span>
      ))}
    </div>
  </div>
</div>

<style>
  .banner-wrap {
    overflow: hidden;
    transform: rotate(-1deg);
    margin: -0.5rem 0;
    position: relative;
    top: 0px;
    position: relative;
    z-index: 10;
  }

  .banner {
    background: var(--color-accent);
    padding: 0.875rem 0;
    width: 110%;
    margin-left: -5%;
    overflow: hidden;
  }

  .track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: scroll 70s linear infinite;
  }

  .track:hover {
    animation-play-state: paused;
  }

  .tool {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    white-space: nowrap;
    padding: 0 2rem;
    border-right: 1px solid rgba(255,255,255,0.2);
  }

  .tool__icon {
    display: flex;
    align-items: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .tool__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-100% / 3)); }
  }

  /* Clients banner */
  .clients-wrap {
    overflow: hidden;
    transform: rotate(-1deg);
    margin: -0.5rem 0;
    position: relative;
    top: 4px;
    z-index: 9;
  }

  .clients-banner {
    background: var(--color-border);
    padding: 2rem 0;
    width: 110%;
    margin-left: -5%;
    overflow: hidden;
  }

  .clients-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: scroll-reverse 110s linear infinite;
  }

  .clients-track:hover {
    animation-play-state: paused;
  }

  .client {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
    white-space: nowrap;
    padding: 0 2.5rem;
    border-right: 1px solid rgba(0, 0, 0, 0.1);
  }

  @keyframes scroll-reverse {
    from { transform: translateX(calc(-100% / 3)); }
    to   { transform: translateX(0); }
  }
</style>
