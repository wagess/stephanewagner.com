---
---

<div class="filters">
  <div class="filters__group">
    <button class="filters__pill filters__pill--active" data-filter-tag="all">Tous</button>
    <button class="filters__pill" data-filter-tag="B2C">B2C</button>
  </div>

  <span class="filters__sep">+</span>

  <button class="filters__featured" data-filter-featured="false" aria-pressed="false">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    Coups de cœur
  </button>
</div>

<script>
  const tagPills = document.querySelectorAll<HTMLButtonElement>('[data-filter-tag]');
  const featuredBtn = document.querySelector<HTMLButtonElement>('[data-filter-featured]');
  const wrappers = document.querySelectorAll<HTMLElement>('.cases__list-wrapper [data-animate][data-year]');
  const listWrapper = document.querySelector<HTMLElement>('.cases__list-wrapper');

  let activeTag = 'all';
  let featuredOnly = false;
  let isFiltering = false;

  async function applyFilters() {
    if (isFiltering) return;
    isFiltering = true;

    listWrapper?.classList.add('is-loading');
    await new Promise(r => setTimeout(r, 200));

    wrappers.forEach(wrapper => {
      const tags = (wrapper.dataset.tags ?? '').split(',');
      const tagMatch = activeTag === 'all' || tags.includes(activeTag);
      const featuredMatch = !featuredOnly || wrapper.dataset.featured === 'true';
      const visible = tagMatch && featuredMatch;
      wrapper.style.display = visible ? '' : 'none';
      if (visible) wrapper.classList.add('visible');
    });

    listWrapper?.classList.remove('is-loading');
    isFiltering = false;
  }

  tagPills.forEach(pill => {
    pill.addEventListener('click', () => {
      tagPills.forEach(p => p.classList.remove('filters__pill--active'));
      pill.classList.add('filters__pill--active');
      activeTag = pill.dataset.filterTag ?? 'all';
      applyFilters();
    });
  });

  featuredBtn?.addEventListener('click', () => {
    featuredOnly = !featuredOnly;
    featuredBtn.dataset.filterFeatured = String(featuredOnly);
    featuredBtn.setAttribute('aria-pressed', String(featuredOnly));
    applyFilters();
  });
</script>

<style>
  .filters {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    margin-top: var(--gap-block);
    margin-bottom: var(--gap-block);
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .filters__sep {
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    color: var(--color-border);
    user-select: none;
  }

  .filters__group {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filters__pill {
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-button);
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    border-radius: var(--radius-pill);
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .filters__pill:hover {
    border-color: var(--color-text-primary);
    color: var(--color-text-primary);
  }

  .filters__pill--active {
    background: var(--color-text-primary);
    border-color: var(--color-text-primary);
    color: var(--color-bg);
  }

  .filters__featured {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-button);
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    border-radius: var(--radius-pill);
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .filters__featured:hover {
    border-color: var(--color-text-primary);
    color: var(--color-text-primary);
  }

  .filters__featured[aria-pressed="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .filters__featured[aria-pressed="true"] svg {
    fill: white;
    stroke: white;
  }
</style>
