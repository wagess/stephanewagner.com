---
interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;
---

<div class="page-line-top"></div>

<header class="page-header">
  <p class="page-header__label">{label}</p>
  <h1 class="page-header__title">{title}</h1>
</header>

<style>
  .page-line-top {
    height: 1px;
    background: var(--color-text-primary);
    margin: 0 var(--spacing-container);
    transform-origin: left;
    animation: scaleFromLeft 1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .page-header {
    margin: 0 var(--spacing-container) 5rem;
    padding: var(--section-spacing) 0 2rem;
    position: relative;
  }

  .page-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-text-primary);
    transform: scaleX(0);
    transform-origin: left;
    animation: scaleFromLeft 1s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;
  }

  .page-header__label {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 11px;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s ease 0.4s both;
  }

  .page-header__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.2;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 500;
    /* max-width: 48rem; */
    animation: fadeInUp 0.8s ease 0.5s both;
  }

  @keyframes scaleFromLeft {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
