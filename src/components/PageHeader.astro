---
interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;
---

<div class="page-line-top"></div>

<header class="page-header">
  <p class="page-header__label">{label}</p>
  <h1 class="page-header__title">{title}</h1>
</header>

<style>
  .page-line-top {
    height: 1px;
    background: var(--color-text-primary);
    margin: 0 var(--spacing-container);
    transform-origin: left;
    animation: scaleFromLeft 1s var(--easing-spring) both;
  }

  .page-header {
    margin: 0 var(--spacing-container) 5rem;
    padding: var(--section-spacing) 0 2rem;
    position: relative;
  }

  .page-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-text-primary);
    transform: scaleX(0);
    transform-origin: left;
    animation: scaleFromLeft 1s var(--easing-spring) 0.3s both;
  }

  .page-header__label {
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-size: var(--font-size-label);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s ease 0.4s both;
  }

  .page-header__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: var(--leading-tight);
    font-family: var(--font-heading);
    font-weight: 300;
    background: linear-gradient(135deg, var(--color-accent-vivid) 0%, var(--color-text-primary) 60%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: fadeInUp 0.8s ease 0.5s both;
  }

  @keyframes scaleFromLeft {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
