---
import ArrowButton from './ArrowButton.astro';

interface Props {
  label: string;
  title: string;
  desc: string;
  backTitle?: string;
  backHref?: string;
}
const { label, title, desc, backTitle, backHref } = Astro.props;
const flippable = !!backTitle;
---
<div class:list={['pillar-wrap', { 'pillar-wrap--flippable': flippable }]}>
  <div class="pillar-inner">

    <div class="pillar-face pillar-face--front">
      <div class="pillar-content">
        <span class="pillar-label">{label}</span>
        <h3 class="pillar-title">{title}</h3>
        <p class="pillar-desc">{desc}</p>
      </div>
      {flippable && (
        <div class="pillar-aside">
          <ArrowButton variant="eye" ariaLabel="Voir le projet associé" />
        </div>
      )}
    </div>

    {backTitle && (
      <a
        class="pillar-face pillar-face--back"
        href={backHref ?? '#'}
        aria-label={`Voir le projet : ${backTitle}`}
      >
        <div class="pillar-content">
          <span class="pillar-hint">Projet associé</span>
          <p class="pillar-back-title">{backTitle}</p>
        </div>
        <div class="pillar-aside">
          <ArrowButton variant="next" />
        </div>
      </a>
    )}

  </div>
</div>

<style>
  .pillar-wrap {
    perspective: 500px;
  }

  .pillar-inner {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.55s var(--easing-bounce);
  }

  .pillar-wrap--flippable {
    cursor: pointer;
  }

  .pillar-wrap--flippable:active .pillar-inner {
    transform: scale(0.97);
  }

  .pillar-wrap--flippable.is-flipped .pillar-inner {
    transform: rotateX(180deg);
  }

  .pillar-wrap--flippable.is-flipped:active .pillar-inner {
    transform: rotateX(180deg) scale(0.97);
  }

  .pillar-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--color-surface);
    border: var(--card-border);
    border-radius: var(--card-radius);
    padding: var(--gap-block);
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--gap-sm);
    height: 180px;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .pillar-face {
      height: 160px;
    }
  }

  .pillar-face--back {
    position: absolute;
    inset: 0;
    transform: rotateX(180deg);
    background: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
    cursor: pointer;
    pointer-events: none;
  }

  .pillar-wrap.is-flipped .pillar-face--back {
    pointer-events: auto;
  }

  /* Zones */
  .pillar-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
    min-width: 0;
  }

  .pillar-aside {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    align-self: stretch;
  }

  .pillar-label {
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-mono);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  /* ArrowButton sur le verso — inversé pour fond accent */
  .pillar-face--back :global(.arrow-btn) {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
    color: var(--color-surface);
  }

  .pillar-title {
    font-size: var(--font-size-card-title);
    line-height: 1.3;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 400;
  }

  .pillar-desc {
    font-size: var(--font-size-body-sm);
    line-height: 1.6;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-weight: 300;
  }

  .pillar-hint {
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-mono);
  }

  .pillar-back-title {
    font-size: 22px;
    line-height: 1.3;
    color: var(--color-surface);
    font-family: var(--font-heading);
    font-weight: 600;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.pillar-wrap--flippable').forEach(card => {
    let leaveTimer: ReturnType<typeof setTimeout>;

    card.addEventListener('mouseenter', () => {
      clearTimeout(leaveTimer);
      card.classList.add('is-flipped');
    });

    card.addEventListener('mouseleave', () => {
      leaveTimer = setTimeout(() => card.classList.remove('is-flipped'), 300);
    });
  });
</script>
