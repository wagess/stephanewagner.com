---
interface Props {
  label: string;
  title: string;
  desc: string;
  backTitle?: string;
  backHref?: string;
}
const { label, title, desc, backTitle, backHref } = Astro.props;
const flippable = !!backTitle;
---
<div class:list={['pillar-wrap', { 'pillar-wrap--flippable': flippable }]}>
  <div class="pillar-inner">

    <div class="pillar-face pillar-face--front">
      <div class="pillar-top">
        <span class="pillar-label">{label}</span>
        <div class="pillar-line"></div>
      </div>
      <h3 class="pillar-title">{title}</h3>
      <p class="pillar-desc">{desc}</p>
    </div>

    {backTitle && (
      <a
        class="pillar-face pillar-face--back"
        href={backHref ?? '#'}
        aria-label={`Voir le projet : ${backTitle}`}
      >
        <span class="pillar-hint">Projet associé</span>
        <p class="pillar-back-title">{backTitle}</p>
        <span class="pillar-arrow">→</span>
      </a>
    )}

  </div>
</div>

<style>
  .pillar-wrap {
    perspective: 500px;
  }

  .pillar-inner {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  .pillar-wrap--flippable {
    cursor: pointer;
  }

  .pillar-wrap--flippable:active .pillar-inner {
    transform: scale(0.97);
  }

  .pillar-wrap--flippable.is-flipped .pillar-inner {
    transform: rotateX(180deg);
  }

  .pillar-wrap--flippable.is-flipped:active .pillar-inner {
    transform: rotateX(180deg) scale(0.97);
  }

  .pillar-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--color-surface);
    border: var(--card-border);
    border-radius: var(--card-radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pillar-face--back {
    position: absolute;
    inset: 0;
    transform: rotateX(180deg);
    justify-content: center;
    gap: 1rem;
    background: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
    cursor: pointer;
    pointer-events: none;
  }

  .pillar-wrap.is-flipped .pillar-face--back {
    pointer-events: auto;
  }

  .pillar-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .pillar-label {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .pillar-line {
    height: 1px;
    width: 2rem;
    background: var(--color-border);
  }

  .pillar-title {
    font-size: 26px;
    line-height: 1.3;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .pillar-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-weight: 300;
  }

  .pillar-hint {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-mono);
  }

  .pillar-back-title {
    font-size: 22px;
    line-height: 1.3;
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .pillar-arrow {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.6);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.pillar-wrap--flippable').forEach(card => {
    let leaveTimer: ReturnType<typeof setTimeout>;

    card.addEventListener('mouseenter', () => {
      clearTimeout(leaveTimer);
      card.classList.add('is-flipped');
    });

    card.addEventListener('mouseleave', () => {
      leaveTimer = setTimeout(() => card.classList.remove('is-flipped'), 300);
    });
  });
</script>
