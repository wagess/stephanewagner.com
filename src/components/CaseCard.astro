---
import YearTag from './YearTag.astro';
import ArrowButton from './ArrowButton.astro';

interface Props {
  index: number;
  title: string;
  summary?: string;
  tags?: string[];
  href: string;
  year: number;
  cover?: string;
  variant?: 'default' | 'secondary';
  featured?: boolean;
  draft?: boolean;
}

const { index, title, summary, tags = [], href, year, cover, variant = 'default', featured = false, draft = false } = Astro.props;

const num = String(index).padStart(2, '0');
const isSecondary = variant === 'secondary';
---

<li class:list={['case-card', { 'case-card--secondary': isSecondary, 'case-card--draft': draft }]} data-year={year} data-featured={featured}>

  {draft ? (
    <div class="case-card__inner">
      <div class="case-card__left">
        <svg class="case-card__icon case-card__icon--lock" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
      <div class="case-card__body">
        <div class="case-card__head">
          <h3 class="case-card__title">{title}</h3>
        </div>
        <div class="case-card__tags">
          <YearTag year={year} />
          {tags.slice(0, 4).map(tag => (
            <span class="case-card__tag">{tag}</span>
          ))}
        </div>
      </div>
      {cover && (
        <div class="case-card__thumb">
          <img src={cover} alt={title} loading="lazy" />
        </div>
      )}
    </div>
  ) : (
    <a href={href} class="case-card__inner" target={isSecondary ? '_blank' : undefined} rel={isSecondary ? 'noopener noreferrer' : undefined}>
      <div class="case-card__left">
        {isSecondary ? (
          <span class="case-card__number">{num}</span>
        ) : (
          <ArrowButton variant="diagonal" />
        )}
      </div>

      <div class="case-card__body">
        <div class="case-card__head">
          <h3 class="case-card__title">{title}</h3>
          {isSecondary && (
            <svg class="case-card__icon case-card__icon--right" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          )}
        </div>

        {!isSecondary && summary && (
          <p class="case-card__summary">{summary}</p>
        )}

        {!isSecondary && (
          <div class="case-card__tags">
            <YearTag year={year} />
            {tags.slice(0, 4).map(tag => (
              <span class="case-card__tag">{tag}</span>
            ))}
            {tags.length > 4 && (
              <span class="case-card__tag case-card__tag--more">+{tags.length - 4}</span>
            )}
          </div>
        )}
      </div>

      {!isSecondary && cover && (
        <div class="case-card__thumb">
          <img src={cover} alt={title} loading="lazy" />
        </div>
      )}
    </a>
  )}

</li>

<style>
  .case-card {
    border-radius: var(--card-radius);
    overflow: hidden;
  }

  .case-card__inner {
    display: flex;
    align-items: center;
    gap: var(--padding-block);
    padding: var(--gap-sm);
    height: 14rem;
    text-decoration: none;
    background: var(--color-surface);
    border: var(--card-border);
    border-radius: var(--card-radius);
    transition: background var(--transition-slow), border-color var(--transition-slow);
  }

  .case-card--secondary .case-card__inner {
    height: auto;
    background: var(--color-surface-secondary);
    padding: 1.25rem 1.5rem;
    border-color: transparent;
    gap: var(--gap-block);
  }

  .case-card--draft .case-card__inner {
    cursor: default;
    opacity: 0.5;
  }

  a.case-card__inner:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .case-card--secondary .case-card__inner:hover {
    background: var(--color-surface-secondary);
    border-color: transparent;
  }

  @media (max-width: 768px) {
    .case-card__inner {
      height: auto;
      padding: 0;
      gap: 0;
      flex-direction: column;
      align-items: flex-start;
    }

    .case-card__body {
      padding: 1rem 1.25rem;
    }

    .case-card:not(.case-card--secondary) .case-card__left {
      display: none;
    }

    .case-card--secondary .case-card__left {
      padding: 1rem 1.25rem;
      padding-bottom: 0;
    }
  }

  .case-card__left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    flex-shrink: 0;
    align-self: stretch;
  }

  .case-card--secondary .case-card__left {
    align-self: auto;
  }

  .case-card__number {
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-mono);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    transition: color var(--transition-slow);
  }

  a.case-card__inner:hover .case-card__number {
    color: var(--color-surface);
  }

  .case-card--secondary .case-card__inner:hover .case-card__number {
    color: var(--color-text-muted);
  }

  .case-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    align-self: flex-start;
  }

  .case-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--gap-sm);
  }

  .case-card--secondary .case-card__head {
    align-items: center;
  }

  .case-card__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 300;
    flex: 1;
    transition: color var(--transition-slow);
  }

  .case-card--secondary .case-card__title {
    color: var(--color-text-primary);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
  }

  a.case-card__inner:hover .case-card__title {
    color: var(--color-surface);
  }

  .case-card--secondary .case-card__inner:hover .case-card__title {
    color: var(--color-accent);
  }

  /* Diagonal arrow button — hover on card */
  a.case-card__inner:hover :global(.arrow-btn--diagonal) {
    background: var(--color-text-primary);
    border-color: rgba(255,255,255,0.5);
    color: var(--color-surface);
    transform: translate(3px, -3px);
  }

  .case-card__icon--lock {
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .case-card__icon--right {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color var(--transition-slow), transform var(--transition-slow);
  }

  .case-card--secondary .case-card__inner:hover .case-card__icon--right {
    color: var(--color-accent);
    transform: translateX(5px);
  }

  .case-card__summary {
    font-size: 16px;
    line-height: var(--leading-relaxed);
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-weight: 300;
    font-style: italic;
    transition: color var(--transition-slow);
  }

  @media (max-width: 768px) {
    .case-card__summary {
      display: none;
    }
  }

  a.case-card__inner:hover .case-card__summary {
    color: var(--color-surface);
  }

  .case-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .case-card__tag {
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.75rem;
    text-transform: uppercase;
    font-family: var(--font-mono);
    transition: color var(--transition-slow), border-color var(--transition-slow);
  }

  a.case-card__inner:hover .case-card__tag {
    color: var(--color-surface);
    border-color: rgba(255,255,255,0.5);
  }

  a.case-card__inner:hover :global(.year-tag) {
    background: var(--color-surface);
    border-color: var(--color-surface);
    color: var(--color-text-primary);
  }

  .case-card__tag--more {
    color: var(--color-text-muted);
    border-color: var(--color-border);
    border-style: dashed;
  }

  a.case-card__inner:hover .case-card__tag--more {
    color: rgba(255,255,255,0.6);
    border-color: rgba(255,255,255,0.3);
  }

  /* Thumbnail */
  .case-card__thumb {
    flex-shrink: 0;
    width: 20%;
    max-height: 10rem;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-border-dark);
    background-color: var(--color-surface);
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: var(--shadow-offset);
    transition: box-shadow var(--transition-slow);
  }

  a.case-card__inner:hover .case-card__thumb {
    box-shadow: 4px 4px 0 0 rgba(0,0,0,0.4);
  }

  .case-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--easing-spring);
  }

  a.case-card__inner:hover .case-card__thumb img {
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .case-card__thumb {
      width: 100%;
      max-height: none;
      aspect-ratio: 16 / 9;
      border-radius: var(--card-radius) var(--card-radius) 0 0;
      border: none;
      box-shadow: none;
      order: -1;
    }

    a.case-card__inner:hover .case-card__thumb {
      box-shadow: none;
    }
  }
</style>
