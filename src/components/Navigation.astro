---
import { getCollection } from 'astro:content';
const { pathname } = Astro.url;
const cases = (await getCollection('cases')).filter(c => !c.id.startsWith('_'));
const caseCount = cases.length;
---
<header class="nav">
  <a href="/" class="nav__logo">
    <img src="/logo-nav.svg" alt="S." width="41" height="34" loading="eager" />
  </a>

  <div class="nav__links">
    <a href="/services" class:list={['nav__link', { 'nav__link--active': pathname.startsWith('/services') }]}>
      Services
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
    <a href="/cases" class:list={['nav__link', { 'nav__link--active': pathname.startsWith('/cases') }]}>
      Études de cas
      <span class="nav__count">{caseCount}</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
    <a href="#approche" class="nav__link">
      Approche
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <polyline points="5 12 12 19 19 12"></polyline>
      </svg>
    </a>
    <a href="/the-wall" class:list={['nav__link', { 'nav__link--active': pathname.startsWith('/the-wall') }]}>
      The Wall
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>

  <a href="https://calendly.com/wagess/30min" target="_blank" rel="noopener noreferrer" class="nav__cta">
    Calendly
  </a>

  <button class="nav__burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
    <span></span>
    <span></span>
  </button>
</header>

<div class="nav__mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="nav__mobile-links">
    <a href="/services" class:list={['nav__mobile-link', { 'nav__mobile-link--active': pathname.startsWith('/services') }]}>
      Services
    </a>
    <a href="/cases" class:list={['nav__mobile-link', { 'nav__mobile-link--active': pathname.startsWith('/cases') }]}>
      Études de cas
      <span class="nav__count">{caseCount}</span>
    </a>
    <a href="#approche" class="nav__mobile-link nav__mobile-link--hidden">
      Approche
    </a>
  </nav>
  <a href="https://calendly.com/wagess/30min" target="_blank" rel="noopener noreferrer" class="nav__cta nav__mobile-cta">
    I have a dream
  </a>
</div>

<script>
  const burger = document.querySelector('.nav__burger') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;

  function openMenu() {
    menu.classList.add('is-open');
    burger.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('is-open');
    burger.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', () => {
    menu.classList.contains('is-open') ? closeMenu() : openMenu();
  });

  menu.querySelectorAll('.nav__mobile-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .nav {
    width: 100%;
    background: var(--color-surface);
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem var(--spacing-container);
    position: relative;
    z-index: 100;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .nav__link:hover {
    opacity: 0.5;
  }

  .nav__count {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-border);
    border-radius: 999px;
    padding: 0.1rem 0.45rem;
    line-height: 1.6;
  }

  .nav__link--active svg {
    transform: rotate(90deg);
  }

  .nav__link--active {
    color: var(--color-accent);
    text-decoration: none;
    outline: 1px solid var(--color-accent);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    animation: frameIn 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes frameIn {
    from {
      outline-color: transparent;
      padding: 0.2rem 0;
    }
    to {
      outline-color: var(--color-accent);
      padding: 0.2rem 0.6rem;
    }
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: var(--color-accent);
    color: white;
    font-family: 'Nunito', sans-serif;
    font-size: 13px;
    font-weight: 800;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .nav__cta:hover {
    opacity: 0.85;
  }

  /* Burger button */
  .nav__burger {
    display: none;
    position: relative;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .nav__burger span {
    display: block;
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .nav__burger span:first-child {
    top: calc(50% - 4px);
  }

  .nav__burger span:last-child {
    top: calc(50% + 4px);
  }

  .nav__burger[aria-expanded="true"] span:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .nav__burger[aria-expanded="true"] span:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Mobile menu panel */
  .nav__mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--color-surface);
    z-index: 99;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    padding: 6rem var(--spacing-container) 3rem;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }

  .nav__mobile-menu.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .nav__mobile-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--gap-block);
    width: 100%;
  }

  .nav__mobile-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(2rem, 8vw, 3rem);
    font-family: var(--font-heading);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav__mobile-link:hover {
    color: var(--color-accent);
  }

  .nav__mobile-link--active {
    color: var(--color-accent);
  }

  .nav__mobile-link--hidden {
    display: none;
  }

  .nav__mobile-cta {
    display: inline-flex !important;
    margin-top: var(--padding-block);
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }

    .nav__cta {
      display: none;
    }

    .nav__burger {
      display: flex;
    }

    .nav__mobile-menu {
      display: flex;
    }
  }
</style>
