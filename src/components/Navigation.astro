---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/index';
const { pathname } = Astro.url;
const lang = (Astro.currentLocale ?? 'fr') as 'fr' | 'en';
const t = useTranslations(lang).nav;
const cases = (await getCollection('cases')).filter(c => c.id.startsWith(`${lang}/`) && !c.id.includes('_template'));
const caseCount = cases.length;
const ctaHref = 'https://calendly.com/wagess/30min';
const lp = (path: string) => `/${lang}${path}`;
---
<header class="nav">
  <a href={lp('/')} class="nav__logo">
    <img src="/logo-nav.svg" alt="S." width="41" height="34" loading="eager" />
  </a>

  <div class="nav__links">
    <a href={lp('/services')} class:list={['nav__link', { 'nav__link--active': pathname.startsWith(`/${lang}/services`) }]}>
      {t.services}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
    <a href={lp('/cases')} class:list={['nav__link', { 'nav__link--active': pathname.startsWith(`/${lang}/cases`) }]}>
      {t.cases}
      <span class="nav__count">{caseCount}</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
    <a href={lp('/the-wall')} class:list={['nav__link', { 'nav__link--active': pathname.startsWith(`/${lang}/the-wall`) }]}>
      {t.wall}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
    <a href={lp('/#approche')} class="nav__link">
      {t.approach}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <polyline points="5 12 12 19 19 12"></polyline>
      </svg>
    </a>
  </div>

  <div class="nav__right">
    <a href={lang === 'fr' ? pathname.replace(/^\/fr/, '/en') : pathname.replace(/^\/en/, '/fr')} class="nav__lang">
      {lang === 'fr' ? 'EN' : 'FR'}
    </a>
    <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="nav__cta">
      {t.cta}
    </a>
  </div>

  <button class="nav__burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
    <span></span>
    <span></span>
  </button>
</header>

<div class="nav__mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="nav__mobile-links">
    <a href={lp('/services')} class:list={['nav__mobile-link', { 'nav__mobile-link--active': pathname.startsWith(`/${lang}/services`) }]}>
      {t.services}
    </a>
    <a href={lp('/cases')} class:list={['nav__mobile-link', { 'nav__mobile-link--active': pathname.startsWith(`/${lang}/cases`) }]}>
      {t.cases}
      <span class="nav__count">{caseCount}</span>
    </a>
    <a href={lp('/#approche')} class="nav__mobile-link nav__mobile-link--hidden">
      {t.approach}
    </a>
    <a href={lp('/the-wall')} class:list={['nav__mobile-link', { 'nav__mobile-link--active': pathname.startsWith(`/${lang}/the-wall`) }]}>
      {t.wall}
    </a>
  </nav>
  <div class="nav__mobile-footer-links">
    <a href={lp('/the-wall')} class="nav__mobile-footer-link">{t.wall}</a>
    <a href="https://shop.stephanewagner.com" target="_blank" rel="noopener noreferrer" class="nav__mobile-footer-link">Shop</a>
    <a href="https://photographie.stephanewagner.com" target="_blank" rel="noopener noreferrer" class="nav__mobile-footer-link">Photographie</a>
  </div>
  <div class="nav__mobile-bottom">
    <a href={lang === 'fr' ? pathname.replace(/^\/fr/, '/en') : pathname.replace(/^\/en/, '/fr')} class="nav__lang">
      {lang === 'fr' ? 'EN' : 'FR'}
    </a>
    <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="nav__cta nav__mobile-cta">
      {t.cta}
    </a>
  </div>
</div>

<script>
  const burger = document.querySelector('.nav__burger') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;

  function openMenu() {
    menu.classList.add('is-open');
    burger.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('is-open');
    burger.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', () => {
    menu.classList.contains('is-open') ? closeMenu() : openMenu();
  });

  menu.querySelectorAll('.nav__mobile-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .nav {
    width: 100%;
    background: var(--color-surface);
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem var(--spacing-container);
    position: relative;
    z-index: 100;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--spacing-block);
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
    transition: opacity var(--transition-base);
  }

  .nav__link:hover {
    opacity: 0.5;
  }

  .nav__count {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.1rem 0.45rem;
    line-height: 1.6;
  }

  .nav__link--active svg {
    transform: rotate(90deg);
  }

  .nav__link--active {
    color: var(--color-accent);
    text-decoration: none;
    outline: 1px solid var(--color-accent);
    border-radius: var(--radius-pill);
    padding: 0.2rem 0.6rem;
    animation: frameIn 0.4s var(--easing-spring) both;
  }

  @keyframes frameIn {
    from {
      outline-color: transparent;
      padding: 0.2rem 0;
    }
    to {
      outline-color: var(--color-accent);
      padding: 0.2rem 0.6rem;
    }
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  .nav__lang {
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-button);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.25rem 0.6rem;
    text-decoration: none;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .nav__lang:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-primary);
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: var(--color-accent);
    color: white;
    font-family: 'Nunito', sans-serif;
    font-size: var(--font-size-sm);
    font-weight: 800;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: opacity var(--transition-base);
  }

  .nav__cta:hover {
    opacity: 0.85;
  }

  /* Burger button */
  .nav__burger {
    display: none;
    position: relative;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .nav__burger span {
    display: block;
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-text-primary);
    border-radius: var(--radius-sm);
    transition: transform var(--transition-slow), opacity var(--transition-slow);
  }

  .nav__burger span:first-child {
    top: calc(50% - 4px);
  }

  .nav__burger span:last-child {
    top: calc(50% + 4px);
  }

  .nav__burger[aria-expanded="true"] span:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .nav__burger[aria-expanded="true"] span:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Mobile menu panel */
  .nav__mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--color-surface);
    z-index: 99;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    padding: 6rem var(--spacing-container) 3rem;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }

  .nav__mobile-menu.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .nav__mobile-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--gap-block);
    width: 100%;
  }

  .nav__mobile-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(2rem, 8vw, 3rem);
    font-family: var(--font-body);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .nav__mobile-link:hover {
    color: var(--color-accent);
  }

  .nav__mobile-link--active {
    color: var(--color-accent);
  }

  .nav__mobile-link--hidden {
    display: none;
  }

  .nav__mobile-footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
    margin-top: var(--gap-block);
    padding-top: var(--gap-block);
    border-top: 1px solid var(--color-border);
    width: 100%;
  }

  .nav__mobile-footer-link {
    font-size: var(--font-size-sm);
    font-family: var(--font-body);
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-base);
  }

  .nav__mobile-footer-link:hover {
    color: var(--color-text-primary);
  }

  .nav__mobile-bottom {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    margin-top: var(--padding-block);
  }

  .nav__mobile-cta {
    display: inline-flex !important;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }

    .nav__right {
      display: none;
    }

    .nav__burger {
      display: flex;
    }

    .nav__mobile-menu {
      display: flex;
    }
  }
</style>
