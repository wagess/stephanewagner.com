---
import { getCollection } from "astro:content";
import CaseCard from './CaseCard.astro';
import CasesFilters from './CasesFilters.astro';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;

const allCases = (await getCollection("cases"))
  .filter(c => !c.id.startsWith('_'))
  .sort((a, b) => b.data.year - a.data.year);

const featuredCases = allCases.filter(c => c.data.featured);
for (let i = featuredCases.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [featuredCases[i], featuredCases[j]] = [featuredCases[j], featuredCases[i]];
}

const cases = limit ? featuredCases.slice(0, limit) : allCases;

---

<section id="cases" class="cases">
  <div class="cases__container">

    {!limit && (
      <div class="cases__header" data-animate>
        <p class="cases__label">Études de cas</p>
        <h2 class="cases__title">Histoires de produits et services</h2>
      </div>
    )}

    {!limit && <CasesFilters />}

    <div class="cases__list-wrapper">
      <ul class="cases__list">
        {cases.map((c, i) => (
          <div data-animate data-year={c.data.year} data-featured={c.data.featured ?? false} data-tags={c.data.tags.join(',')} style={`transition-delay: ${i * 0.10}s`}>
            <CaseCard
              index={i + 1}
              title={c.data.title}
              summary={c.data.star_summary}
              tags={c.data.tags}
              href={c.data.variant === 'secondary' && c.data.external_url ? c.data.external_url : `/cases/${c.id.replace(/\.md$/, '')}`}
              year={c.data.year}
              cover={c.data.cover}
              variant={c.data.variant}
              featured={c.data.featured}
              draft={c.data.draft ?? false}
            />
          </div>
        ))}
      </ul>
      <div class="cases__loader" aria-hidden="true">
        <span class="cases__spinner"></span>
      </div>
    </div>

    {limit && (
      <div class="cases__footer" data-animate>
        <a href="/cases" class="cases__more">Voir tous les projets</a>
      </div>
    )}

  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.cases [data-animate]').forEach(el => observer.observe(el));
</script>

<style>
  .cases {
    padding: var(--section-spacing) var(--spacing-container);
    background: var(--color-bg);
  }

  .cases__container {
    margin: 0 auto;
  }

  [data-animate] {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  [data-animate].visible {
    opacity: 1;
    transform: none;
  }


  .cases__header {
    margin-bottom: 5rem;
    padding-bottom: 2rem;
    position: relative;
  }

  .cases__header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-text-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s var(--easing-spring);
  }

  .cases__header.visible::after {
    transform: scaleX(1);
  }

  .cases__label {
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-size: var(--font-size-label);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin-bottom: var(--gap-sm);
  }

  .cases__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.2;
    font-family: var(--font-heading);
    font-weight: 300;
    background: linear-gradient(135deg, var(--color-accent-vivid) 0%, var(--color-text-primary) 60%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .cases__list-wrapper {
    padding: var(--gap-block) 0;
    position: relative;
  }

  .cases__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    transition: opacity var(--transition-base);
  }

  .cases__list-wrapper.is-loading .cases__list {
    opacity: 0;
    pointer-events: none;
  }

  .cases__loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .cases__list-wrapper.is-loading .cases__loader {
    opacity: 1;
  }

  .cases__spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-text-primary);
    border-radius: var(--radius-circle);
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .cases__footer {
    margin-top: var(--padding-block);
    display: flex;
    justify-content: center;
  }

  .cases__more {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-button);
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-pill);
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .cases__more:hover {
    border-color: var(--color-text-primary);
    color: var(--color-text-primary);
  }
</style>
