---
import { getCollection } from "astro:content";
import CaseCard from './CaseCard.astro';
import CasesFilters from './CasesFilters.astro';
import { useTranslations } from '../i18n/index';

interface Props {
  limit?: number;
  label?: string;
  title?: string;
}

const { limit, label, title } = Astro.props;
const lang = (Astro.currentLocale ?? 'fr') as 'fr' | 'en';
const t = useTranslations(lang);

const locale = lang === 'en' ? 'en' : 'fr';
const allCases = (await getCollection("cases"))
  .filter(c => c.id.startsWith(`${locale}/`) && !c.id.includes('_template'))
  .sort((a, b) => b.data.year - a.data.year);

const featuredCases = allCases.filter(c => c.data.featured);
for (let i = featuredCases.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [featuredCases[i], featuredCases[j]] = [featuredCases[j], featuredCases[i]];
}

const cases = limit ? featuredCases.slice(0, limit) : allCases;

---

<section id="cases" class:list={['cases', { 'cases--with-header': label && title }]}>
  <div class="cases__container">

    {label && title && (
      <div class="cases__header" data-animate>
        <p class="cases__label">{label}</p>
        <h2 class="cases__title">{title}</h2>
      </div>
    )}

    <div class="cases__list-wrapper">
      {!limit && <CasesFilters />}
      <ul class="cases__list">
        {cases.map((c, i) => (
          <div data-animate data-year={c.data.year} data-featured={c.data.featured ?? false} data-tags={c.data.tags.join(',')} style={`transition-delay: ${i * 0.10}s`}>
            <CaseCard
              index={i + 1}
              title={c.data.title}
              summary={c.data.star_summary}
              tags={c.data.tags}
              href={c.data.variant === 'secondary' && c.data.external_url ? c.data.external_url : `/${lang}/cases/${c.id.replace(/^(fr|en)\//, '').replace(/\.md$/, '')}`}
              year={c.data.year}
              cover={c.data.cover}
              variant={c.data.variant}
              featured={c.data.featured}
              draft={c.data.draft ?? false}
            />
          </div>
        ))}
      </ul>
      <div class="cases__loader" aria-hidden="true">
        <span class="cases__spinner"></span>
      </div>
    </div>

    {limit && (
      <div class="cases__footer" data-animate>
        <a href={`/${lang}/cases`} class="cases__more">{t.cases.viewAll}</a>
      </div>
    )}

  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.cases [data-animate]').forEach(el => observer.observe(el));
</script>

<style>
  .cases {
    padding: 0 var(--spacing-container) var(--section-spacing);
  }

  .cases--with-header {
    padding-top: var(--section-spacing);
  }

  .cases__header {
    margin-bottom: var(--section-spacing);
    padding-bottom: var(--gap-block);
    position: relative;
    transition-duration: 0.8s;
  }

  .cases__header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-text-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cases__header.visible::after {
    transform: scaleX(1);
  }

  .cases__label {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 11px;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin-bottom: var(--gap-sm);
  }

  .cases__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.2;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 300;
  }

  .cases__container {
    margin: 0 auto;
  }

  [data-animate] {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  [data-animate].visible {
    opacity: 1;
    transform: none;
  }


  .cases__list-wrapper {
    position: relative;
  }

  .cases__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    transition: opacity var(--transition-base);
  }

  .cases__list-wrapper.is-loading .cases__list {
    opacity: 0;
    pointer-events: none;
  }

  .cases__loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .cases__list-wrapper.is-loading .cases__loader {
    opacity: 1;
  }

  .cases__spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-text-primary);
    border-radius: var(--radius-circle);
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .cases__footer {
    margin-top: var(--padding-block);
    display: flex;
    justify-content: center;
  }

  .cases__more {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: var(--tracking-button);
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-pill);
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .cases__more:hover {
    border-color: var(--color-text-primary);
    color: var(--color-text-primary);
  }
</style>
