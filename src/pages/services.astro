---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Services from '../components/Services.astro';
import VennDiagram from '../components/VennDiagram.astro';
import Footer from '../components/Footer.astro';

const home = await getEntry('home', 'fr');
const { services_label, services_title, services } = home.data;
---

<Layout title="Services — Concepteur Produit" description="Ma trousse de savoir-faire en design produit.">
  <main>
    <PageHeader label={services_label} title={services_title} />
    <Services services={services} showHeader={false} />
    <VennDiagram />
    <Footer />
  </main>
</Layout>

<style>
  main {
    background: var(--color-surface);
    min-height: 100vh;
  }
</style>
