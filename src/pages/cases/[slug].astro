---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import VennDiagram from "../../components/VennDiagram.astro";
import LikeButton from "../../components/LikeButton.astro";
import challengesSvg from "../../assets/challenges.svg";
import iconS from "../../assets/start-with-an-outline.svg";
import iconT from "../../assets/shapes.svg";
import iconA from "../../assets/grid-view.svg";
import iconR from "../../assets/live-interaction.svg";

export async function getStaticPaths() {
  const cases = (await getCollection("cases"))
    .filter(c => !c.id.startsWith('_'))
    .sort((a, b) => b.data.year - a.data.year);
  return cases.map((c, i) => ({
    params: { slug: c.id.replace(/\.md$/, '') },
    props: { case: c, prevCase: cases[i + 1] ?? null, nextCase: cases[i - 1] ?? null },
  }));
}

const { case: c, prevCase, nextCase } = Astro.props;
const { title, cover, banner_image, gallery, gallery_styles, year, tags, star_summary, contexte, probleme, hypothese, solution, methodologie, livrables, resultat, challenges } = c.data as any;

const md = (str: string) => str
  ?.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
  ?.replace(/==(.+?)==/g, '<mark>$1</mark>') ?? '';
---

<Layout title={title}>
  <main>
    <div class="page-line-top"></div>
    <div class="container pb-0">

      <header data-open>
        <div class="header__grid-bg"></div>
        <div class="header__text">
          <div class="label-row">
            <a href="/" class="back-btn" aria-label="Retour à l'accueil">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 5 5 12 12 19"></polyline>
              </svg>
            </a>
            <p class="label">Étude de cas</p>
          </div>
          <h1>{title}</h1>
          <div class="meta">
            <span class="year">{year}</span>
            <ul class="tags">
              {tags?.map((tag: string) => <li>{tag}</li>)}
            </ul>
            <LikeButton slug={c.id} />
          </div>
        </div>
        <div class="cover">
          {cover && <img src={cover} alt={title} class="cover__img" loading="eager" />}
        </div>
          <blockquote class="star-summary" set:html={star_summary.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
      </header>

      <section class="star">

        <div class="star-block">
          <div class="star-block__header">
            <div class="star-letter"><img src={iconS.src} alt="S" class="star-icon" loading="lazy" /></div>
            <h2>Contexte</h2>
          </div>
          <div class="star-content">
            {Array.isArray(contexte)
              ? <ul class="star-list">{contexte.map((item: string) => <li set:html={md(item)} />)}</ul>
              : <p set:html={md(contexte)} />}

            {probleme && (Array.isArray(probleme)
              ? <ul class="star-list star-list--bold">{probleme.map((item: string) => <li set:html={md(item)} />)}</ul>
              : <p class="text--bold" set:html={md(probleme)} />)}
          </div>
        </div>

        <div class="star-block">
          <div class="star-block__header">
            <div class="star-letter"><img src={iconT.src} alt="T" class="star-icon" loading="lazy" /></div>
            <h2>Méthodologie</h2>
          </div>
          <div class="star-content">
            {Array.isArray(methodologie)
              ? <ul class="star-list">{methodologie.map((item: string) => <li set:html={md(item)} />)}</ul>
              : <p set:html={md(methodologie)} />}
          </div>
        </div>

      </section>

    </div>

    <div class="parallax-banner">
      <div class="parallax-banner__image">
        <img src={banner_image} alt={title} class="parallax-banner__img" loading="lazy" />
      </div>
      <div class="parallax-banner__solution">
        <div class="solution-card__group">
          <p class="solution-card__label">Hypothèse</p>
          {Array.isArray(hypothese)
            ? <ul class="solution-card__list">{hypothese.map((item: string) => <li set:html={md(item)} />)}</ul>
            : <p class="solution-card__text" set:html={md(hypothese)} />}
        </div>
        <div class="solution-card__group">
          <p class="solution-card__label">Solution</p>
          {Array.isArray(solution)
            ? <ul class="solution-card__list">{solution.map((item: string) => <li set:html={md(item)} />)}</ul>
            : <p class="solution-card__text" set:html={md(solution)} />}
        </div>
      </div>
    </div>

    <div class="container container--bottom pt-0">

      <section class="star">

        <div class="star-block">
          <div class="star-block__header">
            <div class="star-letter"><img src={iconA.src} alt="A" class="star-icon" loading="lazy" /></div>
            <h2>Livrables</h2>
          </div>
          <div class="star-content">
            {Array.isArray(livrables)
              ? <ul class="star-list">{livrables.map((item: string) => <li set:html={md(item)} />)}</ul>
              : <p set:html={md(livrables)} />}
          </div>
        </div>

        <div class="star-block">
          <div class="star-block__header">
            <div class="star-letter"><img src={iconR.src} alt="R" class="star-icon" loading="lazy" /></div>
            <h2>Résultats</h2>
          </div>
          <div class="star-content">
            {Array.isArray(resultat)
              ? <ul class="star-list">{resultat.map((item: string) => <li set:html={md(item)} />)}</ul>
              : <p set:html={md(resultat)} />}
          </div>
        </div>

      </section>

      <section class="challenges">
        <div class="challenges__title-wrap">
          <img src={challengesSvg.src} alt="Challenges" class="challenges__title" loading="lazy" />
        </div>
        <div class="challenges__body">
          <p class="challenges__subtitle">Principaux challenges rencontrés :</p>
          <ul class="challenges__list">
            {challenges?.slice(0, 2).map((item: string) => (
              <li class="challenges__item">
                <span class="challenges__arrow" aria-hidden="true">→</span>
                <span set:html={md(item)} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      {gallery && gallery.length > 0 && (() => {
        const hasCover = gallery_styles?.some((s) => s === 'cover');
        return (
        <section class={`visuals${gallery.length === 1 ? ' visuals--single' : gallery.length === 2 ? ' visuals--duo' : ''}${hasCover ? ' visuals--has-cover' : ''}`}>
          <div class="visuals__header">
            <div class="star-letter"><img src={iconA.src} alt="" class="star-icon" loading="lazy" /></div>
            <h2>Visuels</h2>
          </div>
          {gallery.map((img, i) => {
            const isCover = gallery_styles?.[i] === 'cover';
            return (
              <div class={isCover ? 'cover' : 'visual-block'}>
                <a href={img} class="glightbox"><img src={img} alt={title} class={isCover ? 'cover__img' : 'visual-block__img'} /></a>
              </div>
            );
          })}
        </section>
        );
      })()}

    </div>
    <nav class="case-nav">
      {prevCase ? (
        <a href={`/cases/${prevCase.id.replace(/\.md$/, '')}`} class="case-nav__btn case-nav__btn--prev">
          <span class="back-btn" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
          </span>
          <span class="case-nav__label">
            <span class="case-nav__hint">Précédent</span>
            <span class="case-nav__title">{prevCase.data.title}</span>
          </span>
        </a>
      ) : <div />}
      {nextCase ? (
        <a href={`/cases/${nextCase.id.replace(/\.md$/, '')}`} class="case-nav__btn case-nav__btn--next">
          <span class="case-nav__label">
            <span class="case-nav__hint">Suivant</span>
            <span class="case-nav__title">{nextCase.data.title}</span>
          </span>
          <span class="back-btn" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </a>
      ) : <div />}
    </nav>

    <VennDiagram />
    <Footer />
  </main>
</Layout>

<style is:global>
  .glightbox-open .goverlay { animation-duration: 0.15s !important; }
  .glightbox-open .gslide { animation-duration: 0.15s !important; }
  .glightbox-closing .goverlay { animation-duration: 0.15s !important; }
  .glightbox-closing .gslide { animation-duration: 0.15s !important; }
</style>

<style>
  main {
    background: var(--color-bg);
    min-height: 100vh;
  }

  .page-line-top {
    height: 1px;
    background: var(--color-text-primary);
    margin: 0 var(--spacing-container);
    transform-origin: left;
    animation: scaleFromLeft 1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes scaleFromLeft {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  @media (max-width: 768px) {
    main {
      padding: 0;
    }
  }

  .container {
    margin: 0 auto;
    padding-top: var(--pt, var(--spacing-block));
    padding-bottom: var(--pb, var(--spacing-block));
    padding-left: var(--pl, var(--spacing-container));
    padding-right: var(--pr, var(--spacing-container));
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* --- page open animation --- */
  [data-open] {
    animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* --- Header --- */
  header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: flex-start;
    gap: var(--gap-block);
    padding-bottom: var(--spacing-block);
    position: relative;
  }

  header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--color-text-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1) 0.5s;
  }

  header[data-open]::after {
    transform: scaleX(1);
  }

  .header__grid-bg {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image:
      linear-gradient(var(--color-text-primary) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-text-primary) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 768px) {
    header {
      grid-template-columns: 1fr;
    }
  }

  .header__text {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    position: relative;
    z-index: 1;
  }

  .label-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .case-nav {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    border-top: 1px solid var(--color-border);
    padding: var(--section-spacing) var(--spacing-container);
  }

  .case-nav__btn {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    text-decoration: none;
    color: var(--color-text-primary);
  }

  .case-nav__btn--next {
    text-align: right;
  }

  .case-nav__btn:hover .back-btn {
    background: var(--color-text-primary);
    border-color: var(--color-text-primary);
    color: var(--color-surface);
  }

  .case-nav__label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .case-nav__hint {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .case-nav__title {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
  }

  .back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-primary);
    text-decoration: none;
    flex-shrink: 0;
  }

  .back-btn:hover {
    background: var(--color-text-primary);
    border-color: var(--color-text-primary);
    color: var(--color-surface);
  }

  .label {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 11px;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  h1 {
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 1.1;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-weight: 400;
    max-width: 60rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    flex-wrap: wrap;
  }

  .year {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags li {
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.75rem;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }

  .cover {
    border: 1px solid #4d4d4d;
    background-color: var(--color-surface);
    border-radius: 10px;
    aspect-ratio: 9 / 6;
    overflow: hidden;
    position: relative;
    z-index: 1;
    box-shadow: 8px 8px 0 0 #202020;
  }

  .cover__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    -webkit-user-select: none;
    pointer-events: none;
  }

  .star-summary {
    grid-column: 1 / -1;
    margin: 0;
    padding: 1.5rem 2rem;
    border-left: 2px solid var(--color-text-primary);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-style: italic;
    color: var(--color-text-primary);
    line-height: 1.6;
    font-family: var(--font-heading);
    font-weight: 400;
  }

  /* --- STAR sections --- */
  .star {
    display: flex;
    flex-wrap: wrap;
  }

  .container > .star:first-of-type {
    border-top: none;
  }

  .star-block {
    flex: 1 1 50%;
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    align-items: start;
    border-bottom: 1px solid var(--color-border);
    padding-top: var(--pt, var(--padding-block));
    padding-bottom: var(--pb, var(--padding-block));
    padding-left: var(--pl, 2.5rem);
    padding-right: var(--pr, 2.5rem);
    box-sizing: border-box;
  }

  .star-block__header {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  .star-block:nth-child(odd) {
    border-right: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .star-block {
      flex: 1 1 100%;
      grid-template-columns: 1fr;
      padding-left: 0;
      padding-right: 0;
      border-right: none;
    }
  }

  .star-letter {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background-color: #F0F0F0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .star-icon {
    width: 2.25rem;
    height: 2.25rem;
    object-fit: contain;
  }

  .star-content {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  h2 {
    font-size: 11px;
    font-family: var(--font-mono);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0;
  }

  h3 {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 400;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    margin: 0;
  }

  h4 {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin: 0;
  }

  p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-weight: 300;
    margin: 0;
    max-width: 52rem;
  }

  /* --- Star lists --- */
  .star-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    max-width: 52rem;
  }

  .star-list li {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-weight: 300;
    padding-left: 1.25rem;
    position: relative;
  }

  .star-list--bold li,
  .text--bold {
    font-weight: 500;
  }

  .star-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-primary);
  }

  .challenges__title-wrap {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .challenges__title-wrap::before {
    content: '';
    position: absolute;
    width: 70%;
    height: 70%;
    background: #fef3f2;
    border-radius: 50%;
  }

  .challenges__title {
    position: relative;
    max-height: 10rem;
    width: auto;
    display: block;
  }

  .challenges__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .challenges__subtitle {
    display: block;
    width: fit-content;
    font-size: 11px;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9B1C1C;
    background-color: #FEF2F2;
    border: 1px solid #FECACA;
    border-radius: 4px;
    padding: 0.25rem 0.6rem;
    margin: 0;
  }

  /* --- Challenges --- */
  .challenges {
    border-bottom: 1px solid var(--color-border);
    padding-top: var(--pt, var(--padding-block));
    padding-bottom: var(--pb, var(--padding-block));
    padding-left: var(--pl, var(--gap-block));
    padding-right: var(--pr, var(--gap-block));
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-block);
    align-items: center;
  }

  @media (max-width: 768px) {
    .challenges {
      padding-left: 0;
      padding-right: 0;
    }
    .challenges__title {
      display: none;
    }
  }

  .challenges__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .challenges__item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-weight: 300;
    max-width: 52rem;
  }

  /* --- Parallax banner --- */
  .parallax-banner {
    height: 85vh;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    background-color: #F4F4F2;
  }

  .parallax-banner__image {
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  .parallax-banner__image::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset -60px 0 40px -20px rgba(0, 0, 0, 0.25);
    pointer-events: none;
    z-index: 1;
  }

  .parallax-banner__img {
    position: absolute;
    top: -10%;
    left: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    will-change: transform;
  }

  .parallax-banner__solution {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--gap-block);
    padding: var(--padding-block) var(--spacing-container) var(--padding-block) 4rem;
  }

  .solution-card__group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .solution-card__label {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .solution-card__text {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    line-height: 1.7;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-weight: 300;
    margin: 0;
  }

  .solution-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .solution-card__list li {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    line-height: 1.7;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-weight: 500;
    padding-left: 1.25rem;
    position: relative;
  }

  .solution-card__list li::before {
    content: "→";
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .parallax-banner {
      grid-template-columns: 1fr;
      grid-template-rows: 1fr 1fr;
      height: 100vh;
    }
    .parallax-banner__image {
      height: 100%;
    }
    .parallax-banner__solution {
      padding: var(--padding-block) var(--spacing-container);
