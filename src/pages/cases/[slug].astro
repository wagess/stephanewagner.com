---
import { getCollection } from "astro:content";

// Redirect les anciennes URLs /cases/{slug} vers /fr/cases/{slug}
export async function getStaticPaths() {
  const cases = (await getCollection("cases"))
    .filter(c => c.id.startsWith('fr/') && !c.id.includes('_template'));
  return cases.map(c => ({
    params: { slug: c.id.replace(/^fr\//, '').replace(/\.md$/, '') },
  }));
}

const { slug } = Astro.params;
---
<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0;url=/fr/cases/${slug}`} />
  <link rel="canonical" href={`/fr/cases/${slug}`} />
</head>
<body></body>
</html>
