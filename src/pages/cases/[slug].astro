.visual-block__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: none;
    transition: filter 0.3s ease, transform 0.3s ease;
    user-select: none;
    -webkit-user-select: none;
    pointer-events: none;
  }

  .visual-block a:hover .visual-block__img {
    filter: drop-shadow(0 16px 40px rgba(0,0,0,0.18)) drop-shadow(0 4px 10px rgba(0,0,0,0.10));
