---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Services from '../../components/Services.astro';
import VennDiagram from '../../components/VennDiagram.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/index';

const home = await getEntry('home', 'fr');
const { services_label, services_title, services } = home.data;
const t = useTranslations('fr');
---

<Layout title={t.services.pageTitle} description={t.services.pageDescription}>
  <main>
    <PageHeader label={services_label} title={services_title} />
    <Services services={services} showHeader={false} />
    <VennDiagram />
    <Footer />
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
  }
</style>
