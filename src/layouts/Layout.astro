---
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Concepteur Produit — Portfolio", ogImage: ogImageProp } = Astro.props;
const lang = (Astro.currentLocale ?? 'fr') as 'fr' | 'en';

const SITE = 'https://stephanewagner.com';
const { pathname } = Astro.url;
const canonicalUrl = `${SITE}${pathname}`;
const alternateFr = `${SITE}${pathname.replace(/^\/(fr|en)/, '/fr')}`;
const alternateEn = `${SITE}${pathname.replace(/^\/(fr|en)/, '/en')}`;
const ogImage = ogImageProp?.startsWith('http') ? ogImageProp : `${SITE}${ogImageProp ?? '/avatar.webp'}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={alternateFr} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="x-default" href={alternateFr} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_CA' : 'en_CA'} />
    <meta property="og:locale:alternate" content={lang === 'fr' ? 'en_CA' : 'fr_CA'} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Libre+Franklin:wght@300;400;500;600&family=Nunito:wght@700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Navigation />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-heading: 'Fraunces', serif;
    --font-body: 'Libre Franklin', sans-serif;
    --font-mono: 'Space Mono', monospace;

    --color-accent: #694878;
    --color-accent-vivid: #8619e0;
    --color-bg: #FAFAFA;
    --color-bg-warm: #e7e7e7;
    --color-surface: #ffffff;
    --color-surface-secondary: #DCDEE0;
    --color-surface-subtle: #F0F0F0;
    --color-text-primary: #0A0A0A;
    --color-text-secondary: #666666;
    --color-text-muted: #999999;
    --color-border: #E5E5E5;
    --color-border-dark: #4d4d4d;
    --color-shadow: #202020;
    --color-danger: #9B1C1C;
    --color-danger-bg: #FEF2F2;
    --color-danger-border: #FECACA;

    --spacing-container: 4.5rem;
    --section-spacing: 6rem;
    --spacing-block: 2.5rem;
    --padding-block: 3rem;
    --gap-block: 2rem;
    --gap-sm: 1.5rem;
    --gap-md: 1rem;
    --gap-xs: 0.75rem;
    --card-border: 1px solid var(--color-border);
    --card-radius: 10px;
    --border-strong: 1px solid var(--color-text-primary);

    /* Border radius */
    --radius-pill: 999px;
    --radius-sm: 2px;
    --radius-circle: 50%;

    /* Typography */
    --font-size-label: 11px;
    --font-size-xs: 12px;
    --font-size-sm: 13px;
    --font-size-body-sm: 15px;
    --font-size-body: 16px;
    --font-size-card-title: 26px;
    --leading-tight: 1.25;
    --leading-relaxed: 1.7;
    --tracking-label: 0.3em;
    --tracking-mono: 0.2em;
    --tracking-button: 0.15em;

    /* Transitions & easing */
    --transition-fast: 0.15s ease;
    --transition-base: 0.2s ease;
    --transition-slow: 0.3s ease;
    --easing-spring: cubic-bezier(0.22, 1, 0.36, 1);
    --easing-bounce: cubic-bezier(0.34, 1.4, 0.64, 1);

    /* Gradients */
    --gradient-vivid: linear-gradient(135deg, var(--color-accent-vivid) 0%, var(--color-text-primary) 60%);
    --gradient-accent-soft: linear-gradient(135deg, var(--color-accent-vivid) 0%, #2a0f52 100%);

    /* Shadows */
    --shadow-offset: 4px 4px 0 0 var(--color-shadow);
  }

  @media (max-width: 768px) {
    :root {
      --spacing-container: 1.25rem;
      --section-spacing: 3rem;
      --spacing-block: 1.5rem;
      --padding-block: 1.5rem;
      --gap-block: 1rem;
      --gap-sm: 0.75rem;
      --gap-md: 0.625rem;
      --gap-xs: 0.5rem;
    }
  }

  /* Utilitaires padding & margin
     Échelle : 0=0 | 1=gap-xs | 2=gap-sm | 3=gap-block | 4=padding-block | 5=spacing-block | 6=section-spacing
     Note : --gap-md (1rem) disponible comme token mais sans classe utilitaire */
  .pt-0 { padding-top: 0 !important; }
  .pt-1 { padding-top: var(--gap-xs) !important; }
  .pt-2 { padding-top: var(--gap-sm) !important; }
  .pt-3 { padding-top: var(--gap-block) !important; }
  .pt-4 { padding-top: var(--padding-block) !important; }
  .pt-5 { padding-top: var(--spacing-block) !important; }
  .pt-6 { padding-top: var(--section-spacing) !important; }

  .pb-0 { padding-bottom: 0 !important; }
  .pb-1 { padding-bottom: var(--gap-xs) !important; }
  .pb-2 { padding-bottom: var(--gap-sm) !important; }
  .pb-3 { padding-bottom: var(--gap-block) !important; }
  .pb-4 { padding-bottom: var(--padding-block) !important; }
  .pb-5 { padding-bottom: var(--spacing-block) !important; }
  .pb-6 { padding-bottom: var(--section-spacing) !important; }

  .pl-0 { padding-left: 0 !important; }
  .pl-1 { padding-left: var(--gap-xs) !important; }
  .pl-2 { padding-left: var(--gap-sm) !important; }
  .pl-3 { padding-left: var(--gap-block) !important; }
  .pl-4 { padding-left: var(--padding-block) !important; }
  .pl-5 { padding-left: var(--spacing-block) !important; }
  .pl-6 { padding-left: var(--spacing-container) !important; }

  .pr-0 { padding-right: 0 !important; }
  .pr-1 { padding-right: var(--gap-xs) !important; }
  .pr-2 { padding-right: var(--gap-sm) !important; }
  .pr-3 { padding-right: var(--gap-block) !important; }
  .pr-4 { padding-right: var(--padding-block) !important; }
  .pr-5 { padding-right: var(--spacing-block) !important; }
  .pr-6 { padding-right: var(--spacing-container) !important; }

  .mt-0 { margin-top: 0 !important; }
  .mt-1 { margin-top: var(--gap-xs) !important; }
  .mt-2 { margin-top: var(--gap-sm) !important; }
  .mt-3 { margin-top: var(--gap-block) !important; }
  .mt-4 { margin-top: var(--padding-block) !important; }
  .mt-5 { margin-top: var(--spacing-block) !important; }
  .mt-6 { margin-top: var(--section-spacing) !important; }

  .mb-0 { margin-bottom: 0 !important; }
  .mb-1 { margin-bottom: var(--gap-xs) !important; }
  .mb-2 { margin-bottom: var(--gap-sm) !important; }
  .mb-3 { margin-bottom: var(--gap-block) !important; }
  .mb-4 { margin-bottom: var(--padding-block) !important; }
  .mb-5 { margin-bottom: var(--spacing-block) !important; }
  .mb-6 { margin-bottom: var(--section-spacing) !important; }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
  }

  body {
    background: linear-gradient(160deg, var(--color-bg) 0%, var(--color-bg-warm) 100%);
    background-attachment: fixed;
    color: var(--color-text-primary);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .animated-accent {
    background: linear-gradient(135deg, #8619e0, #e040fb, #3d0aad, #c44de8);
    background-size: 300% 300%;
    animation: accentShift 9s ease infinite;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  @keyframes accentShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ── Utility ─────────────────────────────────────────── */
  .hide-mobile { display: none !important; }

  @media (min-width: 769px) {
    .hide-mobile { display: revert !important; }
  }
</style>
